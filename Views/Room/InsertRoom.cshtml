@using (Html.BeginForm("InsertRoom", "Room", FormMethod.Post))
{
    <div class="container mt-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-primary fw-bold">Add Room</h2>
            <a href="/Room/Index" class="btn btn-secondary btn-lg">Back</a>
        </div>

        <!-- Card -->
        <div class="card shadow rounded p-4">

            <!-- Room Name -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Room Name</label>
                <input type="text" name="roomName" class="form-control" placeholder="Enter room name" required />
            </div>

            <!-- Room Size -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Room Size</label>
                <input type="text" name="roomSize" class="form-control" placeholder="Enter room size" required />
            </div>

            <!-- Availability -->
            <div class="mb-3">
                <label class="form-label fw-semibold d-block">Is Available</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="isAvailable" value="true" id="availableYes" />
                    <label class="form-check-label" for="availableYes">Yes</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="isAvailable" value="false" id="availableNo" />
                    <label class="form-check-label" for="availableNo">No</label>
                </div>
            </div>

            <!-- Location -->
            <div class="mb-4">
                <label class="form-label fw-semibold">Location</label>
                <input type="text" name="location" class="form-control" placeholder="Enter location" required />
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-success btn-lg">
                + Add Room
            </button>

        </div>

    </div>
}