@using (Html.BeginForm("InsertStudent", "Student", FormMethod.Post))
{
    <div class="container mt-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-primary fw-bold">Add Student</h2>
            <a href="/Student/Index" class="btn btn-secondary btn-lg">Back</a>
        </div>

        <!-- Card -->
        <div class="card shadow rounded p-4">

            <!-- Student Name -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Student Name</label>
                <input type="text" name="studentName" class="form-control" placeholder="Enter student name" required />
            </div>

            <!-- Student Number -->
            <div class="mb-4">
                <label class="form-label fw-semibold">Student Number</label>
                <input type="text" name="studentNo" class="form-control" placeholder="Enter student number" required />
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-success btn-lg">
                + Add Student
            </button>

        </div>

    </div>
}