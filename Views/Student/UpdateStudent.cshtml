@model wateen12148MCVWebApp.Models.Student

@using (Html.BeginForm("UpdateStudent", "Student", FormMethod.Post))
{
    <div class="container mt-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-primary fw-bold">Update Student</h2>
            <a href="/Student/Index" class="btn btn-secondary btn-lg">Back</a>
        </div>

        <!-- Card -->
        <div class="card shadow rounded p-4">

            @Html.HiddenFor(m => m.studentId)

            <!-- Student Name -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Student Name</label>
                @Html.TextBoxFor(m => m.studentName, new { @class = "form-control", placeholder = "Enter student name" })
            </div>

            <!-- Student Number -->
            <div class="mb-4">
                <label class="form-label fw-semibold">Student Number</label>
                @Html.TextBoxFor(m => m.studentNo, new { @class = "form-control", placeholder = "Enter student number" })
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary btn-lg">
                Update Student
            </button>

        </div>

    </div>
}