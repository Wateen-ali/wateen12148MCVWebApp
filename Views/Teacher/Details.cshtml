@model wateen12148MCVWebApp.Models.Teacher

<div class="container mt-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Teacher Details</h2>
        <a href="/Teacher/Index" class="btn btn-secondary btn-lg">Back</a>
    </div>

    <!-- Card -->
    <div class="card shadow rounded p-4">

        <!-- Teacher Name -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Teacher Name</label>
            <div class="form-control bg-light">
                @Model.teacherName
            </div>
        </div>

        <!-- Teacher Number -->
        <div class="mb-4">
            <label class="form-label fw-semibold">Teacher Number</label>
            <div class="form-control bg-light">
                @Model.teacherNo
            </div>
        </div>

        <!-- Actions -->
        <div>
            <a href="/Teacher/UpdateTeacher/@Model.teacherId" class="btn btn-primary btn-lg me-2">
                Edit
            </a>

            <a href="/Teacher/Index" class="btn btn-secondary btn-lg">
                Back
            </a>
        </div>

    </div>

</div>