@model wateen12148MCVWebApp.Models.Teacher

@using (Html.BeginForm("UpdateTeacher", "Teacher", FormMethod.Post))
{
    <div class="container mt-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-primary fw-bold">Update Teacher</h2>
            <a href="/Teacher/Index" class="btn btn-secondary btn-lg">Back</a>
        </div>

        <!-- Card -->
        <div class="card shadow rounded p-4">

            @Html.HiddenFor(m => m.teacherId)

            <!-- Teacher Name -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Teacher Name</label>
                @Html.TextBoxFor(m => m.teacherName, new { @class = "form-control", placeholder = "Enter teacher name" })
            </div>

            <!-- Teacher Number -->
            <div class="mb-4">
                <label class="form-label fw-semibold">Teacher Number</label>
                @Html.TextBoxFor(m => m.teacherNo, new { @class = "form-control", placeholder = "Enter teacher number" })
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary btn-lg">
                Update Teacher
            </button>

        </div>

    </div>
}